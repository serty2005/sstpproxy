APP_ENV=production
LOG_LEVEL=info

SSTP_EGRESS_IMAGE=docker.io/your-namespace/sstpproxy-sstp-egress:latest
TELEGRAM_PROXY_IMAGE=docker.io/your-namespace/sstpproxy-telegram-proxy:latest
CONTROL_PLANE_IMAGE=docker.io/your-namespace/sstpproxy-control-plane:latest

SSTP_REMOTEHOST=vpn.example.com
SSTP_USERNAME=sstp-user
SSTP_PASSWORD=replace-me

PUBLIC_HOST=proxy.example.com
XRAY_PORT=4443
MTG_PORT=4430
CONTROL_PLANE_PORT=8080
CONTROL_PLANE_ADMIN_TOKEN=replace-with-strong-random-bearer-token

XRAY_REALITY_DEST=www.cloudflare.com:443
XRAY_REALITY_SERVER_NAMES=www.cloudflare.com,cdn.cloudflare.com

POSTGRES_DB=sstpproxy
POSTGRES_USER=sstpproxy
POSTGRES_PASSWORD=replace-with-strong-password

TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_PROXY_URL=http://telegram-proxy:3128

XRAY_VERSION=v26.3.27
MTG_IMAGE_TAG=2.2.8
